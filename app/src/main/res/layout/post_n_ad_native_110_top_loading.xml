<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/unified"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerLay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:duration="500">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/colorCardBackground"
            android:orientation="vertical"
            android:paddingHorizontal="5dp"
            android:paddingVertical="5dp">

            <RelativeLayout
                android:id="@+id/media"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:layout_marginVertical="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ad_app_icon"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:alpha="0.5"
                        android:foreground="@drawable/ic_shimmer_background"
                        app:shapeAppearance="@style/ShapeAppearance.MaterialComponents.MediumComponent" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_ad"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:background="@drawable/ic_ad_label_background"
                                android:backgroundTint="#FEC318"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="8dp"
                                android:text="AD"
                                android:textColor="@color/colorBlack"
                                android:textSize="10dp" />

                            <TextView
                                android:id="@+id/ad_headline"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:alpha="0.5"
                                android:ellipsize="end"
                                android:foreground="@drawable/ic_shimmer_background"
                                android:lines="1"
                                android:maxLines="1"
                                android:textSize="12dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/ad_body"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:alpha="0.5"
                            android:ellipsize="end"
                            android:foreground="@drawable/ic_shimmer_background"
                            android:lines="1"
                            android:textSize="9dp" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/ad_call_to_action"
                        android:layout_width="wrap_content"
                        android:layout_height="25dp"
                        android:layout_gravity="center"
                        android:layout_margin="5dp"
                        android:alpha="0.5"
                        android:background="@drawable/ic_shimmer_background"
                        android:gravity="center"
                        android:padding="0dp"
                        android:textAllCaps="true"
                        android:textColor="@color/colorWhite"
                        android:textSize="10dp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/colorAccent" />
                </LinearLayout>
            </RelativeLayout>
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>
</com.google.android.gms.ads.nativead.NativeAdView>