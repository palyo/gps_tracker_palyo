<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layout_parent"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_gravity="bottom"
    android:background="#75000000"
    android:gravity="bottom"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/ic_bg_rounded_sheet"
        android:paddingTop="@dimen/_15sdp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_prompt_title"
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:layout_marginHorizontal="@dimen/_18sdp"
                android:fontFamily="@font/bold"
                android:gravity="center_vertical"
                android:text="Find and turn it on"
                android:textColor="@color/colorText"
                android:textSize="@dimen/_16ssp" />

            <LinearLayout
                android:id="@+id/layout_overlay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_15sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/ic_bg_rounded_12sdp"
                android:backgroundTint="#17000000"
                android:gravity="center"
                android:paddingHorizontal="@dimen/_10sdp"
                android:paddingVertical="@dimen/_10sdp">

                <ImageView
                    android:id="@+id/tv_prompt_msg"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/_30sdp"
                    android:adjustViewBounds="true"
                    android:fontFamily="@font/bold"
                    android:src="@mipmap/ic_launcher_round" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_8sdp"
                    android:layout_marginEnd="@dimen/_37sdp"
                    android:layout_weight="1"
                    android:fontFamily="@font/medium"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:text="@string/app_name_manifest"
                    android:textColor="@color/colorText"
                    android:textSize="@dimen/_11ssp" />


            </LinearLayout>

        </LinearLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/layout_overlay1"
            android:layout_width="@dimen/_110sdp"
            android:layout_height="@dimen/_90sdp"
            android:layout_gravity="end|bottom"
            android:layout_marginTop="@dimen/_37sdp"
            android:layout_marginEnd="-25dp"
            android:elevation="@dimen/_15sdp"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/anim_switch" />
    </FrameLayout>
</LinearLayout>