<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.camera"
        android:required="true" />

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />

    <application
        android:name=".App"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_manifest"
        android:largeHeap="true"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Tracker"
        tools:replace="android:label"
        tools:targetApi="UPSIDE_DOWN_CAKE">
        <activity
            android:name=".ui.updates.PromptActivity"
            android:exported="false"
            android:theme="@style/Theme.Space.Prompt" />
        <activity
            android:name=".ui.updates.AppPermissionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.updates.OnboardingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.updates.TemplatesActivity"
            android:exported="false" />
        <activity
            android:name=".ui.updates.LocationsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.updates.HomeActivity"
            android:exported="false" />
        <activity
            android:name=".ui.ViewCollectionActivity"
            android:exported="false" />
        <activity
            android:name=".ui.GPSCameraActivity"
            android:exported="false" />

        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-4852962457779682~5605383182"
            tools:replace="android:value" />
        <meta-data
            android:name="com.google.android.gms.ads.flag.NATIVE_AD_DEBUGGER_ENABLED"
            android:value="false" />
        <activity
            android:name=".ui.updates.FeedbackActivity"
            android:exported="false" />
        <activity
            android:name=".ui.LauncherActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.AppSettingsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.AppLanguageActivity"
            android:exported="false" />
        <activity
            android:name=".ui.NearActivity"
            android:exported="false" />
        <activity
            android:name=".ui.CompassActivity"
            android:exported="false" />
        <activity
            android:name=".ui.SpeedViewActivity"
            android:exported="false" />

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyB2nul3xCrb5SZqVgH9jJ_sBpS1sXFtRq4" />

        <activity
            android:name=".ui.RouteActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.AreaCalcActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.MapActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.ToolsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

        <activity
            android:name=".afterCall.ui.activity.PostCallActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity=".PostCallActivity"
            android:theme="@style/Theme.SlideAnimWindow"
            android:turnScreenOn="true"
            android:windowSoftInputMode="adjustPan" />

        <receiver
            android:name=".afterCall.receiver.CallReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>
        <receiver
            android:name=".afterCall.receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <service
            android:name=".afterCall.service.MyJobService"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.BIND_JOB_SERVICE">
            <intent-filter>
                <action android:name="com.firebase.jobdispatcher.ACTION_EXECUTE" />
            </intent-filter>
        </service>
        <service
            android:name=".afterCall.service.ForegroundService"
            android:enabled="true"
            android:exported="true"
            android:foregroundServiceType="phoneCall" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false">
            <meta-data
                android:name="aanibrothers.tracker.io.afterCall.appStartup.WebViewInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="aanibrothers.tracker.io.afterCall.appStartup.MobileAdsInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="aanibrothers.tracker.io.afterCall.appStartup.PostCallInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>
    </application>

</manifest>
